# ─── Google Gemini AI (tek anahtar) ───────────────────────────
# https://aistudio.google.com/ — Ücretsiz API key
# Boş bırakılırsa mock yanıtlar üretilir; UI tam çalışır.
GEMINI_API_KEY=your_gemini_api_key_here

# Model (varsayılan: gemini-2.5-flash)
GEMINI_MODEL=gemini-2.5-flash

# ─── TwelveData (opsiyonel — piyasa verileri) ────────────────
# https://twelvedata.com/
TWELVEDATA_API_KEY=
