# ─── Google Gemini AI ─────────────────────────────────────────
# https://aistudio.google.com/ adresinden ücretsiz key oluşturabilirsiniz.
# Boş bırakılırsa mock yanıtlar üretilir; UI tam çalışır.

# Çoklu Key Desteği (Round-Robin + 429/5xx Otomatik Rotasyon + 401/403 Dead Key Elimination):
# 20 adede kadar key tanımlayabilirsiniz. Kota/erişim sorununda otomatik diğerine geçer.
# Daha fazla key = daha yüksek dayanıklılık. Önerilen: en az 3 key.
GEMINI_API_KEY_1=your_gemini_api_key_here
GEMINI_API_KEY_2=
GEMINI_API_KEY_3=
GEMINI_API_KEY_4=
GEMINI_API_KEY_5=
GEMINI_API_KEY_6=
GEMINI_API_KEY_7=
# GEMINI_API_KEY_8 ... GEMINI_API_KEY_20 de eklenebilir.

# Geriye uyumluluk: Tek key kullanmak isterseniz aşağıdaki da çalışır.
# GEMINI_API_KEY=your_gemini_api_key_here

# Gemini model adı (varsayılan: gemini-2.5-flash)
# Diğer seçenekler: gemini-2.0-flash, gemini-1.5-flash, gemini-1.5-pro
GEMINI_MODEL=gemini-2.5-flash

# ─── TwelveData ──────────────────────────────────────────────
# https://twelvedata.com/ — Gerçek zamanlı piyasa verileri: altın, döviz, hisse, kripto
TWELVEDATA_API_KEY=your_twelvedata_api_key_here
